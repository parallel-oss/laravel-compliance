{
  "principles": [
    {
      "id": "01",
      "name": "Conditions for Collection and Processing",
      "optional": false,
      "sections": [
        {
          "id": "Collection Limitation Principle",
          "name": "",
          "description": "There should be limits to the collection of personal data and any such data should be obtained by lawful and fair means and, where appropriate, with the knowledge or consent of the data subject.",
          "controls": [
            {
              "id": "ilthg277",
              "externalId": "DCH-116"
            },
            {
              "id": "g0ua496j",
              "externalId": "DCH-117"
            },
            {
              "id": "ha8y2ail",
              "externalId": "PRI-225"
            }
          ]
        },
        {
          "id": "Data Minimization Principle",
          "name": "",
          "description": "A data controller or processor should minimize the creation, use, processing, storage, maintenance, dissemination or disclosure of any collected PII to only that which is directly necessary to accomplish a business objective.\n\nThis data should only be maintained for as long as necessary to accomplish that objective and should be securely deleted immediately when no longer necessary.",
          "controls": [
            {
              "id": "kppgzi0t",
              "externalId": "DCH-118"
            },
            {
              "id": "tvs8d0q3",
              "externalId": "DCH-119"
            },
            {
              "id": "ovam9iqx",
              "externalId": "PRI-226"
            }
          ]
        },
        {
          "id": "Openness & Transparency Principle",
          "name": "",
          "description": "There should be a general policy of openness about developments, practices and policies with respect to personal data. Means should be readily available of establishing the existence and nature of personal data and the main purposes of their use, as well as the identity and usual residence of the data controller.",
          "controls": [
            {
              "id": "cv4ogjtp",
              "externalId": "DCH-124"
            },
            {
              "id": "6hy5rn6d",
              "externalId": "DCH-125"
            },
            {
              "id": "y2ge8x08",
              "externalId": "PRI-239"
            }
          ]
        }
      ]
    },
