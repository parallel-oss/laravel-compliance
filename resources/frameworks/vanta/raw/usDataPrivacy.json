            },
            {
              "id": "feyagfvx",
              "externalId": "PRI-235"
            }
          ]
        },
        {
          "id": "Use Limitation Principle",
          "name": "",
          "description": "Personal data should not be disclosed, made available or otherwise used for purposes other than those specified, except \n\na) with the consent of the data subject, or\n\nb) by the authority of law.",
          "controls": [
            {
              "id": "ydsl4m0h",
              "externalId": "DCH-121"
            },
