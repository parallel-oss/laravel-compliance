    {
      "id": "03",
      "name": "PII Sharing, Transfer and Disclosure (Controllers/Processors)",
      "optional": false,
      "sections": [
        {
          "id": "Purpose Specification Principle",
          "name": "",
          "description": "The purposes for which personal data are collected should be specified not later than at the time of data collection and the subsequent use limited to the fulfillment of those purposes or such others as are not incompatible with those purposes and as are specified on each occasion of change of purpose.",
          "controls": [
            {
              "id": "mnc3vw9s",
              "externalId": "PRI-228"
            },
            {
              "id": "ytf0wwqx",
              "externalId": "PRI-229"
