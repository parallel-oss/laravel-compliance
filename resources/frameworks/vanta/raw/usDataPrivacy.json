    {
      "id": "04",
      "name": "Obligations to PII Principals (Controllers/Processors)",
      "optional": false,
      "sections": [
        {
          "id": "Data Quality Principle",
          "name": "",
          "description": "Personal data should be relevant to the purposes for which they are to be used, and, to the extent necessary for those purposes, should be accurate, complete and kept up-to-date.",
          "controls": [
            {
              "id": "94ezmwb1",
              "externalId": "DCH-120"
            },
            {
              "id": "gp78s5vb",
              "externalId": "PRI-227"
            }
          ]
        },
        {
          "id": "Individual Participation Principle",
          "name": "",
          "description": "An individual should have the right:\n\na) to obtain from a data controller, or otherwise, confirmation of whether or not the data controller has data relating to them;\n\nb) to have data relating to them communicated to them, within a reasonable time, at a charge, if any, that is not excessive; in a reasonable manner, and in a form that is readily intelligible to them;\n\nc) to be given reasons if a request made under subparagraphs (a) and (b) is denied and to be able to challenge such denial; and\n\nd) to challenge data relating to them and, if the challenge is successful, to have the data erased, rectified, completed or amended;",
          "controls": [
            {
